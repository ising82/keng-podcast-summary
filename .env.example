# ===== 必填 =====
# Gemini API key（從 https://aistudio.google.com/app/apikey 取得）
GEMINI_API_KEY=

# ===== 選填 =====
# 改用 OpenAI 時填入；同時也要把 LLM_PROVIDER 改成 openai
LLM_PROVIDER=gemini            # gemini | openai
OPENAI_API_KEY=

# 模型名稱（可不填，使用預設）
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# 每次最多處理幾集（避免單次跑爆 quota；預設 3，音檔模式謚警不要太高）
MAX_NEW_EPISODES_PER_PODCAST=3

# 音檔最大允許大小 (MB)，超過則 fallback 到 show notes
MAX_AUDIO_MB=120

# 設成 1 則不下載音檔，全部用 show notes 文字摘要（省額度用）
SKIP_AUDIO=

# 部署網址（用於 sitemap / canonical）
SITE_URL=https://keng-podcast-summary.vercel.app

# 設成 1 不會呼叫 LLM，方便本地測試
DRY_RUN=
